Options -Indexes
RewriteEngine On
RewriteBase /signal/

# 1. YYYY-MM-DD.html → Clean URL (/signal/YYYY-MM-DD) 301 리다이렉트
RewriteCond %{THE_REQUEST} \s/+signal/([0-9]{4}-[0-9]{2}-[0-9]{2})\.html[\s?] [NC]
RewriteRule .* /signal/%1 [R=301,L]

# 2. Clean URL /signal/YYYY-MM-DD → YYYY-MM-DD.html (내부 서빙)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
